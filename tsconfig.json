{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node", "@playwright/test"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include":["tests/**/*.ts", "data/**/*.ts", "playwright.config.ts", "debug/**/*.ts"],
  "exclude":["node_modules","dist"]
}
